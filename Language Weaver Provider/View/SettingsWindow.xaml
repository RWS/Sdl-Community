<Window x:Class="LanguageWeaverProvider.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LanguageWeaverProvider.View"
        xmlns:viewModel="clr-namespace:LanguageWeaverProvider.ViewModel"
        mc:Ignorable="d"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        BorderThickness="1"
        BorderBrush="#c0c0c0"
        WindowStyle="None"
		AllowsTransparency="True"
        ResizeMode="CanResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance viewModel:SettingsViewModel}"
        Title="Settings" MinHeight="400" Width="650">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Sdl.Desktop.Platform.Styles;component/ButtonResources.xaml" />
                <ResourceDictionary Source="/Sdl.Desktop.Platform.Styles;component/DataGridResources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/LanguageWeaverProvider;component/Controls/ProgressIndicator.xaml" />
                <ResourceDictionary Source="pack://application:,,,/LanguageWeaverProvider;component/Controls/WatermarkTextBoxResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="10">
        <Grid>
            <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center"
                          Margin="15,12,5,2" Orientation="Horizontal">
                    <CheckBox 
                    IsChecked="{Binding UseCustomName}"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="Friendly provider name"/>
                    <Image Source="../Resources/Information.png" 
                 Height="16" HorizontalAlignment="Left"
                 RenderOptions.BitmapScalingMode="NearestNeighbor"
                 RenderOptions.EdgeMode="Aliased" 
                 VerticalAlignment="Center"
                 Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
                                 Text="When this option is enabled, the provider's name will display as 'Language Weaver - Custom Name'."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <TextBox Grid.Row="1" IsEnabled="{Binding UseCustomName}"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               Height="24"
               Width="150"
               Margin="35,2,5,2"  Text="{Binding CustomName}"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Center"
              Margin="15,2,5,2" Orientation="Horizontal">
                    <CheckBox 
                  IsChecked="{Binding IncludeTags}"
                  VerticalAlignment="Center"
                  VerticalContentAlignment="Center"
                  Content="Include tags in translations"/>
                    <Image Source="../Resources/Information.png" 
              Height="16" HorizontalAlignment="Left"
              RenderOptions.BitmapScalingMode="NearestNeighbor"
              RenderOptions.EdgeMode="Aliased" 
              VerticalAlignment="Center"
              Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
                          Text="When this option is enabled, segments will be sent for translation with their corresponding tags. Conversely, if the option is disabled, the Target Segments will lack any formatting or tags."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="3"
              VerticalAlignment="Center"
              Margin="15,2,5,2" Orientation="Horizontal">
                    <CheckBox 
                  IsChecked="{Binding ResendDrafts}"
                  VerticalAlignment="Center"
                  VerticalContentAlignment="Center"
                  Content="Re-translation of unconfirmed segments"/>
                    <Image Source="../Resources/Information.png" 
              Height="16" HorizontalAlignment="Left"
              RenderOptions.BitmapScalingMode="NearestNeighbor"
              RenderOptions.EdgeMode="Aliased" 
              VerticalAlignment="Center"
              Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
                          Text="When this option is enabled, previously translated but unconfirmed segments will be sent to the service for translation each time you revisit them."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="4"
   VerticalAlignment="Center"
   Margin="15,2,5,2" Orientation="Horizontal">
                    <CheckBox 
       IsChecked="{Binding AutosendFeedback}"
       VerticalAlignment="Center"
       VerticalContentAlignment="Center"
       Content="Feedback for Language Weaver translations"/>
                    <Image Source="../Resources/Information.png" 
   Height="16" HorizontalAlignment="Left"
   RenderOptions.BitmapScalingMode="NearestNeighbor"
   RenderOptions.EdgeMode="Aliased" 
   VerticalAlignment="Center"
   Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
               Text="When this option is enabled, segments that have been translated using the Language Weaver service will be automatically submitted for feedback."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="5"
           VerticalAlignment="Center"
           Margin="15,2,5,2" Orientation="Horizontal">
                    <CheckBox 
               IsChecked="{Binding UsePreLookup}"
               VerticalAlignment="Center"
               VerticalContentAlignment="Center"
               Content="Pre-Lookup Find/Replace"/>
                    <Image Source="../Resources/Information.png" 
           Height="16" HorizontalAlignment="Left"
           RenderOptions.BitmapScalingMode="NearestNeighbor"
           RenderOptions.EdgeMode="Aliased" 
           VerticalAlignment="Center"
           Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
       Text="Uses terms from a text file to tailor source text before translation, enhancing context and accuracy."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="6" VerticalAlignment="Center"
          Margin="15,2,5,2" Orientation="Horizontal">
                    <TextBox IsEnabled="False" Margin="20,0,0,0" Width="400" Height="24" Text="{Binding PreLookupFilePath}"
                   />

                    <Button HorizontalAlignment="Left"
                  Width="80"
                  Height="24"
                  Cursor="Hand"
                  Margin="5,0,0,0"
                  IsEnabled="{Binding UsePreLookup}"
                  Command="{Binding BrowseFileCommand}"
                  CommandParameter="PreLookupFilePath"
                  Padding="0" Content="Browse"/>
                </StackPanel>

                <StackPanel Grid.Row="7"
          VerticalAlignment="Center"
          Margin="15,2,5,2" Orientation="Horizontal">
                    <CheckBox 
              IsChecked="{Binding UsePostLookup}"
              VerticalAlignment="Center"
              VerticalContentAlignment="Center"
              Content="Post-Lookup Find/Replace"/>
                    <Image Source="../Resources/Information.png" 
          Height="16" HorizontalAlignment="Left"
          RenderOptions.BitmapScalingMode="NearestNeighbor"
          RenderOptions.EdgeMode="Aliased" 
          VerticalAlignment="Center"
          Margin="5,0,0,0">
                        <Image.ToolTip>
                            <StackPanel>
                                <TextBlock MaxWidth="600" TextWrapping="Wrap" 
  Text="Applies terms from a text file to the machine-translated target text, ensuring terminological precision and consistency."/>
                            </StackPanel>
                        </Image.ToolTip>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="8" VerticalAlignment="Center"
          Margin="15,2,5,2" Orientation="Horizontal">
                    <TextBox Margin="20,0,0,0" IsEnabled="False" Width="400" Height="24" Text="{Binding PostLookupFilePath}"
                              />

                    <Button HorizontalAlignment="Left"
                              Width="80"
                              Height="24"
                              Cursor="Hand"
                              Margin="5,0,0,0"
                              Command="{Binding BrowseFileCommand}"
                              CommandParameter="PostLookupFilePath"
                              IsEnabled="{Binding UsePostLookup}"
                              Padding="0" Content="Browse"/>
                </StackPanel>
            </Grid>

            <Separator Grid.Row="1" 
                   VerticalAlignment="Top"
                   Background="#FFBFCDD4"/>

            <StackPanel 
               Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
               Margin="16">
                       <Button 
                            Style="{StaticResource Sdl.Button.PrimaryStyle}"
                            Content="OK"
                            Margin="16 0"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="DemiBold"
                            Height="26"
                            Width="120">

                        </Button>
                        <Button 
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource Sdl.Button.SecondaryStyle}"
                            Content="Cancel"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="DemiBold"
                            Height="26"
                            Width="120">
                        </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
