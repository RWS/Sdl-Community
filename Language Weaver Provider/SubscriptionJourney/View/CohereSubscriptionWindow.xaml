<Window x:Class="LanguageWeaverProvider.SubscriptionJourney.View.CohereSubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LanguageWeaverProvider.SubscriptionJourney.ViewModel"
		xmlns:converters="clr-namespace:LanguageWeaverProvider.SubscriptionJourney.Converters"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        SizeToContent="Height"
        d:DataContext="{d:DesignInstance local:SubscriptionViewModel}"
        WindowStartupLocation="CenterScreen"
        Title="{Binding WindowTitle}" Width="600" MinHeight="150">
    <Window.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Window Header -->
        <TextBlock 
            Grid.Row="0" Grid.Column="1"
            HorizontalAlignment="Left"
            Text="{Binding Title}"
            FontSize="14"
            FontWeight="Bold"
            Margin="20, 5"/>

        <Image 
            Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Height="48"
            Width="48"
            Margin="10,0,0,0"
            Source="../Resources/Information.png"/>
        <TextBlock 
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Left"
            Text="{Binding Description}"
            FontSize="14"
            TextWrapping="Wrap"
            FontWeight="Light"
            Margin="20 15"/>

        <Grid Grid.Row="2" Margin="15 10" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Checkbox on the left -->
            <!-- Use Plugin Resources and replace the hardcoded content -->
            <CheckBox Grid.Column="0"
                      Visibility="{Binding IsDoNotShowAgainVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                      IsChecked="{Binding DoNotShowThisAgain}"
              VerticalAlignment="Center"
              Content="Do not show this again" />

            <!-- Buttons on the right -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                
                <Button 
                        Padding="25 5"
                Command="{Binding PrimaryCommand}"
                Content="{Binding PrimaryButtonContent}"
                Visibility="{Binding ShowPrimaryButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="10,0,0,0" />
                
                <Button Padding="25 5"
                Command="{Binding SecondaryCommand}"
                Content="{Binding SecondaryButtonContent}"
                Visibility="{Binding ShowSecondaryButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="10,0,0,0" />

                <Button Padding="25 5"
                Content="{Binding CancelContent}"
                IsCancel="True"
                Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
